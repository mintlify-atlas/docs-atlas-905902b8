  "keyFeatures": [
    "Calculates taxi fares based on origin and destination neighborhoods",
    "Supports 5 pricing sectors plus special fixed-rate routes",
    "Automatic day/night rate determination using Colombia time (UTC-5)",
    "Special holiday surcharges for Holy Week (Thursday/Friday) and December 16-31",
    "Separate fare tables for Terminal de Transporte routes",
    "Exact neighborhood name matching with accent normalization",
    "AWS Lambda deployment via SAM with API Gateway caching",
    "Multi-environment CI/CD pipeline (QA, Staging, Production)",
    "Swagger UI documentation at /docs",
    "Full test coverage with Jest"
  ],
  "publicApiSurface": [
    "POST /api/v2026/calculate-fare",
    "GET /api/v2026/zones",
    "GET /api/v2026/sector?barrio=<name>",
    "GET /api/v2026/barrios",
    "GET /api/v2026/rutas-especiales",
    "GET /health",
    "GET /docs"
  ]
